generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model EnmRole {
  role_id     String @id @db.Char(1)
  role_name   String @db.VarChar(20)
  description String @db.VarChar(50)
  users       User[]

  @@map("enm_roles")
}

model EnmQuestionType {
  type_id     String     @id @db.Char(1)
  type_name   String     @db.VarChar(20)
  description String     @db.VarChar(50)
  questions   Question[]

  @@map("enm_question_types")
}

model EnmMediaType {
  type_id     String            @id @db.Char(1)
  type_name   String            @db.VarChar(20)
  description String            @db.VarChar(50)
  attachments MediaAttachment[]

  @@map("enm_media_types")
}

model User {
  user_no         BigInt          @id @default(autoincrement())
  user_id         String          @unique(map: "user_id") @db.VarChar(10)
  username        String          @db.VarChar(50)
  email           String          @unique(map: "email") @db.VarChar(255)
  role_id         String          @db.Char(1)
  is_withdrawn    IsWithdrawn?    @default(N)
  created_at      DateTime?       @default(now()) @db.DateTime(0)
  student_classes ClassStudent[]
  taught_classes  Class[]         @relation("TeacherClasses")
  exam_results    ExamResult[]
  created_exams   Exam[]
  created_groups  Group[]
  parent_links    ParentStudent[] @relation("ParentLink")
  child_links     ParentStudent[] @relation("ChildLink")
  created_sqs     Question[]
  solve_results   SolveResult[]
  study_logs      StudyLog[]
  authored_cmts   UserComment[]   @relation("AuthoredComments")
  received_cmts   UserComment[]   @relation("ReceivedComments")
  role            EnmRole         @relation(fields: [role_id], references: [role_id], onUpdate: Restrict, map: "fk_user_role")

  @@index([role_id], map: "fk_user_role")
  @@map("users")
}

model Class {
  class_id   BigInt         @id @default(autoincrement())
  teacher_no BigInt
  class_name String         @db.VarChar(100)
  created_at DateTime?      @default(now()) @db.DateTime(0)
  students   ClassStudent[]
  teacher    User           @relation("TeacherClasses", fields: [teacher_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_class_teacher")
  exams      Exam[]

  @@index([teacher_no], map: "fk_class_teacher")
  @@map("classes")
}

model ClassStudent {
  class_id   BigInt
  student_no BigInt
  class      Class  @relation(fields: [class_id], references: [class_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_cs_class")
  student    User   @relation(fields: [student_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_cs_student")

  @@id([class_id, student_no])
  @@index([student_no], map: "fk_cs_student")
  @@map("class_students")
}

model ParentStudent {
  parent_no  BigInt
  student_no BigInt
  parent     User   @relation("ParentLink", fields: [parent_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_ps_parent")
  student    User   @relation("ChildLink", fields: [student_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_ps_student")

  @@id([parent_no, student_no])
  @@index([student_no], map: "fk_ps_student")
  @@map("parent_students")
}

model Group {
  group_id        BigInt     @id @default(autoincrement())
  creator_no      BigInt
  parent_group_id BigInt?
  depth           Int?       @default(1) @db.TinyInt
  name            String     @db.VarChar(100)
  description     String?    @db.Text
  created_at      DateTime?  @default(now()) @db.DateTime(0)
  creator         User       @relation(fields: [creator_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_group_creator")
  parent_group    Group?     @relation("GroupHierarchy", fields: [parent_group_id], references: [group_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_group_parent")
  child_groups    Group[]    @relation("GroupHierarchy")
  questions       Question[]

  @@index([creator_no], map: "fk_group_creator")
  @@index([parent_group_id], map: "fk_group_parent")
  @@map("groups")
}

model Question {
  question_id      BigInt            @id @default(autoincrement())
  creator_no       BigInt
  group_id         BigInt?
  question_type_id String            @default("M") @db.Char(1)
  title            String            @db.VarChar(255)
  question         String            @db.Text
  content          String?           @db.Text
  answer           String            @db.Text
  explanation      String?           @db.Text
  hint             String?           @db.Text
  difficulty       Int?              @default(1) @db.TinyInt
  is_public        Boolean?          @default(false)
  is_deleted       IsDeleted?        @default(N)
  time_limit       Int?              @default(0)
  created_at       DateTime?         @default(now()) @db.DateTime(0)
  exams            ExamQuestion[]
  attachments      MediaAttachment[]
  options          QuestionOption[]
  tags             QuestionTag[]
  creator          User              @relation(fields: [creator_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_question_creator")
  group            Group?            @relation(fields: [group_id], references: [group_id], onUpdate: Restrict, map: "fk_question_group")
  type             EnmQuestionType   @relation(fields: [question_type_id], references: [type_id], onUpdate: Restrict, map: "fk_question_type")
  solve_results    SolveResult[]
  study_logs       StudyLog[]
  comments         UserComment[]

  @@index([creator_no], map: "fk_question_creator")
  @@index([group_id], map: "fk_question_group")
  @@index([question_type_id], map: "fk_question_type")
  @@map("questions")
}

model QuestionOption {
  option_id     BigInt   @id @default(autoincrement())
  question_id   BigInt
  option_number Int      @db.TinyInt
  content       String   @db.Text
  is_answer     Boolean? @default(false)
  question      Question @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_option_q")

  @@index([question_id], map: "fk_option_q")
  @@map("question_options")
}

model MediaAttachment {
  media_id      BigInt       @id @default(autoincrement())
  question_id   BigInt
  media_type_id String       @db.Char(1)
  media_url     String       @db.Text
  sort_order    Int?         @default(0)
  question      Question     @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_media_q")
  type          EnmMediaType @relation(fields: [media_type_id], references: [type_id], onUpdate: Restrict, map: "fk_media_type")

  @@index([question_id], map: "fk_media_q")
  @@index([media_type_id], map: "fk_media_type")
  @@map("media_attachments")
}

model Tag {
  tag_id     BigInt        @id @default(autoincrement())
  tag_name   String        @unique(map: "tag_name") @db.VarChar(50)
  created_at DateTime?     @default(now()) @db.DateTime(0)
  questions  QuestionTag[]

  @@map("tags")
}

model QuestionTag {
  question_id BigInt
  tag_id      BigInt
  question    Question @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_qt_q")
  tag         Tag      @relation(fields: [tag_id], references: [tag_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_qt_t")

  @@id([question_id, tag_id])
  @@index([tag_id], map: "fk_qt_t")
  @@map("question_tags")
}

model Exam {
  exam_id       BigInt         @id @default(autoincrement())
  creator_no    BigInt
  class_id      BigInt?
  exam_name     String         @db.VarChar(255)
  start_time    DateTime       @db.DateTime(0)
  end_time      DateTime       @db.DateTime(0)
  location      String?        @db.VarChar(100)
  is_auto_score Boolean?       @default(true)
  created_at    DateTime?      @default(now()) @db.DateTime(0)
  questions     ExamQuestion[]
  results       ExamResult[]
  class         Class?         @relation(fields: [class_id], references: [class_id], onUpdate: Restrict, map: "fk_exam_class")
  creator       User           @relation(fields: [creator_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_exam_creator")
  solves        SolveResult[]

  @@index([class_id], map: "fk_exam_class")
  @@index([creator_no], map: "fk_exam_creator")
  @@map("exams")
}

model ExamQuestion {
  exam_id        BigInt
  question_id    BigInt
  question_order Int
  score          Int?     @default(10)
  exam           Exam     @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_eq_exam")
  question       Question @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_eq_question")

  @@id([exam_id, question_id])
  @@index([question_id], map: "fk_eq_question")
  @@map("exam_questions")
}

model ExamResult {
  result_id       BigInt    @id @default(autoincrement())
  exam_id         BigInt
  student_no      BigInt
  total_score     Int?      @default(0)
  student_rank    Int?
  total_examinees Int?
  grade           Grade?
  ai_comment      String?   @db.Text
  teacher_comment String?   @db.Text
  submitted_at    DateTime? @default(now()) @db.DateTime(0)
  exam            Exam      @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_er_exam")
  student         User      @relation(fields: [student_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_er_student")

  @@index([exam_id], map: "fk_er_exam")
  @@index([student_no], map: "fk_er_student")
  @@map("exam_results")
}

model UserComment {
  comment_id     BigInt    @id @default(autoincrement())
  author_no      BigInt
  target_user_no BigInt?
  question_id    BigInt
  content        String    @db.Text
  created_at     DateTime? @default(now()) @db.DateTime(0)
  author         User      @relation("AuthoredComments", fields: [author_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_author")
  question       Question  @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_q")
  target_user    User?     @relation("ReceivedComments", fields: [target_user_no], references: [user_no], onUpdate: Restrict, map: "fk_comment_target")

  @@index([author_no], map: "fk_comment_author")
  @@index([question_id], map: "fk_comment_q")
  @@index([target_user_no], map: "fk_comment_target")
  @@map("user_comments")
}

model StudyLog {
  log_id         BigInt    @id @default(autoincrement())
  user_no        BigInt
  question_id    BigInt
  user_memo      String?   @db.Text
  is_correct     Boolean?  @default(false)
  try_count      Int?      @default(0)
  last_played_at DateTime? @default(now()) @updatedAt @db.DateTime(0)
  next_review_at DateTime? @db.DateTime(0)
  question       Question  @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_log_q")
  user           User      @relation(fields: [user_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_log_user")

  @@index([question_id], map: "fk_log_q")
  @@index([user_no], map: "fk_log_user")
  @@map("study_logs")
}

model SolveResult {
  result_id        BigInt    @id @default(autoincrement())
  user_no          BigInt
  question_id      BigInt
  exam_id          BigInt?
  submitted_answer String?   @db.Text
  is_correct       Boolean
  time_taken       Int       @default(0)
  solved_at        DateTime? @default(now()) @db.DateTime(0)
  exam             Exam?     @relation(fields: [exam_id], references: [exam_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_result_exam")
  question         Question  @relation(fields: [question_id], references: [question_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_result_q")
  user             User      @relation(fields: [user_no], references: [user_no], onDelete: Cascade, onUpdate: Restrict, map: "fk_result_user")

  @@index([exam_id], map: "fk_result_exam")
  @@index([question_id], map: "fk_result_q")
  @@index([user_no], map: "fk_result_user")
  @@map("solve_results")
}

enum IsWithdrawn {
  Y
  N
}

enum IsDeleted {
  Y
  N
  T
}

enum Grade {
  SU   @map("수")
  UU   @map("우")
  MI   @map("미")
  YANG @map("가")
  GA   @map("양")
}
